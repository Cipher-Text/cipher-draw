# Cipher Draw - Environment Variables
# Copy this file to .env.local for local development

# =============================================================================
# Phase 1: Feature Flags (Currently in use)
# =============================================================================

# Enable authentication features (login, register, profile)
# Default: false (Phase 2 feature)
NEXT_PUBLIC_FEATURE_AUTH=false

# Enable document save/load features (requires backend)
# Default: false (Phase 2 feature)
NEXT_PUBLIC_FEATURE_SAVE=false

# =============================================================================
# Phase 2: Backend Configuration (Not yet implemented)
# =============================================================================

# Database connection string
# Example: postgresql://user:password@localhost:5432/cipher_draw
# DATABASE_URL=

# Redis connection string for sessions and caching
# Example: redis://localhost:6379
# REDIS_URL=

# JWT secret for token signing (use a long random string)
# IMPORTANT: Change this in production!
# JWT_SECRET=

# JWT token expiry times
# JWT_ACCESS_TOKEN_EXPIRY=15m
# JWT_REFRESH_TOKEN_EXPIRY=30d

# =============================================================================
# Phase 2: OAuth Providers (Not yet implemented)
# =============================================================================

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth callback URLs (adjust for your domain)
# NEXT_PUBLIC_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# =============================================================================
# Phase 3: AI Configuration (Not yet implemented)
# =============================================================================

# NOTE: AI keys are stored CLIENT-SIDE in localStorage by design (BYOAI)
# Server-side keys are optional for team/enterprise deployments only

# Optional: Server-side AI proxy key for shared team usage
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GEMINI_API_KEY=

# Ollama base URL for local AI (no key needed)
# NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Phase 4: External Services (Not yet implemented)
# =============================================================================

# AWS S3 for file storage (exports, avatars)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# Email service (for auth verification, notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@cipherdraw.io

# =============================================================================
# Monitoring & Analytics (Not yet implemented)
# =============================================================================

# Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# Plausible or self-hosted analytics
# NEXT_PUBLIC_ANALYTICS_URL=

# =============================================================================
# Development & Testing
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application URL (used for OAuth callbacks, share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL (when frontend and backend are separate)
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Enable debug logging
# DEBUG=true

# =============================================================================
# Build Configuration
# =============================================================================

# Next.js build optimization
# ANALYZE=false

# Disable telemetry
# NEXT_TELEMETRY_DISABLED=1
